<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <PropertyGroup>
        <PackageId>Functional.Microsoft.OpenAPI.Extensions</PackageId>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Version>0.0.1-alpha</Version>
        <Authors>Vladimir Rogozhin</Authors>
        <Description>
            Experimental F# adapter for Microsoft.OpenAPI 
        </Description>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.OpenApi" Version="1.3.0-preview" />
      <PackageReference Include="Microsoft.OpenApi.Readers" Version="1.3.0-preview" />
    </ItemGroup>

    <ItemGroup>
      <Compile Include="StringExtensions.fs" />
      <Compile Include="SeqExtensions.fs" />
      <Compile Include="Results.fs" />
      <Compile Include="OpenApiTools.fs" />
      <Compile Include="OpenApiReaderTypes.fs" />
      <Compile Include="OpenApiReaderTools.fs" />
    </ItemGroup>

</Project>
