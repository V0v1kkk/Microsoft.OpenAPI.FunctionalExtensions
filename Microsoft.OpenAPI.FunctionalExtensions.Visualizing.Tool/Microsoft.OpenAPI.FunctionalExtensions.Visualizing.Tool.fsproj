<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0</TargetFramework>
        <PackAsTool>true</PackAsTool>
        <PackageId>Functional.Microsoft.OpenAPI.Extensions.Tool</PackageId>
        <Version>0.2.0-alpha</Version>
        <ToolCommandName>openapi-fx</ToolCommandName>
        <Authors>Vladimir</Authors>
        <Description>CLI tool for OpenAPI schema visualization, merge, and scissors operations.</Description>
        <PackageTags>openapi;fsharp;cli;visualization;merge</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Program.fs" />
    </ItemGroup>

    <ItemGroup>
      <Content Include=".dockerignore" />
      <Content Include="Dockerfile" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Argu" Version="6.2.5" />
    <PackageReference Include="Microsoft.OpenApi" Version="3.6.0" />
    <PackageReference Include="Microsoft.OpenApi.YamlReader" Version="3.6.0" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\Microsoft.OpenAPI.FunctionalExtensions.Visualizing\Microsoft.OpenAPI.FunctionalExtensions.Visualizing.fsproj" />
    </ItemGroup>

</Project>
